{
  "version": 2,
  "name": "telad-fleet",
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "npm install --omit=dev",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/healthz",                    "destination": "/api/index.js" },
    { "source": "/api/auth/:path*",            "destination": "/api/index.js" },
    { "source": "/api/vehicles/:path*",        "destination": "/api/index.js" },
    { "source": "/api/drivers/:path*",         "destination": "/api/index.js" },
    { "source": "/api/maintenance/:path*",     "destination": "/api/index.js" },
    { "source": "/api/appointments/:path*",    "destination": "/api/index.js" },
    { "source": "/api/regions/:path*",         "destination": "/api/index.js" },
    { "source": "/api/accidents/:path*",       "destination": "/api/index.js" },
    { "source": "/api/violations/:path*",      "destination": "/api/index.js" },
    { "source": "/api/financial/:path*",       "destination": "/api/index.js" },
    { "source": "/api/employees/:path*",       "destination": "/api/index.js" },
    { "source": "/api/handovers/:path*",       "destination": "/api/index.js" },
    { "source": "/api/gps/:path*",             "destination": "/api/index.js" },
    { "source": "/api/reports/:path*",         "destination": "/api/index.js" },
    { "source": "/api/ai/:path*",              "destination": "/api/index.js" },
    { "source": "/api/logs",                   "destination": "/api/index.js" },
    { "source": "/api/dev-requests/:path*",    "destination": "/api/index.js" },
    { "source": "/api/users/:path*",           "destination": "/api/index.js" },
    { "source": "/api/health",                 "destination": "/api/index.js" },
    { "source": "/api/version",                "destination": "/api/index.js" },
    { "source": "/api/dashboard",              "destination": "/api/index.js" },
    { "source": "/api/alerts",                 "destination": "/api/index.js" },
    { "source": "/api/fleet",                  "destination": "/api/index.js" },
    { "source": "/api/(.*)",                   "destination": "/api/index.js" },
    { "source": "/(.*)",                       "destination": "/frontend/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",          "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy",        "value": "geolocation=(self), camera=(self)" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    },
    {
      "source": "/(.+\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff2|webp))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}

