# ═══════════════════════════════════════════════════════════════════════
# TELAD FLEET – Environment Configuration Example
# Copy this file to backend/.env and fill in the values
# NEVER commit the real .env file to version control
# ═══════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Skew Protection ──────────────────────────────────────────────────────
# Set this to your git commit SHA (or any unique string) at deploy time.
# The server stamps every response with X-Deploy-Id: <DEPLOY_ID>.
# The client detects changes and prompts the user to reload, preventing
# asset 404s and state mismatches between old-client and new-server.
# Example CI/CD injection:  DEPLOY_ID=$(git rev-parse HEAD)
# If not set, the server generates a random ID per process start.
DEPLOY_ID=

# ── Security ────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=8h

# ── Database (PostgreSQL) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telad_fleet
DB_USER=telad_user
DB_PASS=your_db_password
DB_SSL=false

# ── Redis (Cache) ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ── Email (Nodemailer) ───────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
EMAIL_FROM=TELAD FLEET <noreply@fna.sa>

# ── SMS (Twilio) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# ─── Data Persistence ────────────────────────────────────────────────────
# Absolute path where JSON data files are stored.
# Defaults to backend/data/ when not set.
# In production, point to a persistent volume directory.
DATA_DIR=/var/www/telad-fleet/data

# ── AI / OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── GitHub Integration (Dev Requests panel) ──────────────────────────────
# Required to auto-create GitHub Issues from the admin Dev Requests panel.
# GITHUB_TOKEN: Personal Access Token with repo:write scope (or fine-grained
#               token scoped to this repository with Issues:write permission).
# GITHUB_REPO : "owner/repository-name"  e.g. "fahd65658-bit/Telad-fleet"
GITHUB_TOKEN=
GITHUB_REPO=fahd65658-bit/Telad-fleet

# ── Domain ───────────────────────────────────────────────────────────────
DOMAIN=fna.sa
API_URL=https://api.fna.sa
FRONTEND_URL=https://fna.sa
