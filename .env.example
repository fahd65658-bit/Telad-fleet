# ═══════════════════════════════════════════════════════════════════════
# TELAD FLEET – Environment Configuration Example
# Copy this file to backend/.env and fill in the values
# NEVER commit the real .env file to version control
# ═══════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Security ────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=8h

# ── Database (PostgreSQL) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telad_fleet
DB_USER=telad_user
DB_PASS=your_db_password
DB_SSL=false

# ── Redis (Cache) ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ── Email (Nodemailer) ───────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
EMAIL_FROM=TELAD FLEET <noreply@fna.sa>

# ── SMS (Twilio) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# ── AI / OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Domain ───────────────────────────────────────────────────────────────
DOMAIN=fna.sa
API_URL=https://api.fna.sa
FRONTEND_URL=https://fna.sa
