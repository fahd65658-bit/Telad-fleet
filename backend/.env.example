# Server
PORT=5000
NODE_ENV=development

# Security
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-too

# PostgreSQL — leave blank to use in-memory store
DATABASE_URL=
# Or use individual vars:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telad_fleet
DB_USER=postgres
DB_PASS=
DB_SSL=false
# Set DB_SSL_REJECT_UNAUTHORIZED=true in production with valid SSL certificates
DB_SSL_REJECT_UNAUTHORIZED=true

# Redis — leave blank to disable caching
REDIS_URL=

# Email (SMTP) — leave blank to disable email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@fna.sa

# AI — leave blank to use mock risk scoring
OPENAI_API_KEY=
