# ═══════════════════════════════════════════════════════════════════════
# TELAD FLEET – Backend Environment Variables
# Copy this file to .env and fill in real values before production deploy
# ═══════════════════════════════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=production

# JWT — MUST change before going live (use: openssl rand -hex 64)
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# Skew Protection — set to git commit SHA at deploy time
# If not set, a random ID is generated per process start
DEPLOY_ID=

# Data Persistence
# Absolute path for JSON data files. Defaults to backend/data/ if not set.
# In production, point to a directory that survives deployments (e.g. a mounted volume).
DATA_DIR=/var/www/telad-fleet/data

# Frontend URL (used in CORS whitelist)
FRONTEND_URL=https://fna.sa

# PostgreSQL (for production — replace JSON persistence when scaling)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telad_fleet
DB_USER=telad_user
DB_PASS=CHANGE_THIS_PASSWORD

# GitHub Integration (Admin Dev-Request panel — optional)
# PAT with Issues:write scope, or fine-grained token scoped to this repo
GITHUB_TOKEN=
GITHUB_REPO=fahd65658-bit/Telad-fleet

# Optional: OpenAI integration (future)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ════════════════════════════════════════════
# GitHub App Configuration — TELAD Fleet Manager
# Register at: https://github.com/settings/apps/new
# Use app-manifest.json for automatic registration
# ════════════════════════════════════════════

# App Identity
GITHUB_APP_ID=
GITHUB_APP_NAME=telad-fleet-manager

# Authentication
GITHUB_APP_PRIVATE_KEY_PATH=./github-app/private-key.pem
# OR inline (for cloud deployments):
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook Security (generate with: openssl rand -hex 32)
GITHUB_APP_WEBHOOK_SECRET=

# Installation
GITHUB_APP_INSTALLATION_ID=

# OAuth (for user login via GitHub)
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_CALLBACK_URL=https://fna.sa/github/callback

# Webhook forwarding (local dev only — use smee.io)
SMEE_URL=

# Feature flags
GITHUB_APP_ENABLED=true
GITHUB_APP_AUTO_MAINTENANCE=true
GITHUB_APP_NOTIFY_ON_DEPLOY=true
GITHUB_APP_EMERGENCY_ALERTS=true
GITHUB_APP_ENABLE_DEV_TEST_WEBHOOK=false
# GitHub App integration
GITHUB_APP_ENABLED=false
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_WEBHOOK_URL=https://api.fna.sa/api/github/webhook
GITHUB_APP_REDIRECT_URL=https://fna.sa/github/callback
