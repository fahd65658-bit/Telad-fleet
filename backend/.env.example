# ═══════════════════════════════════════════════════════════════════════
# TELAD FLEET – Backend Environment Variables
# Copy this file to .env and fill in real values before production deploy
# Generate secrets with: openssl rand -hex 64
# ═══════════════════════════════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development

# JWT — MUST change before going live
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_HEX_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (used in CORS whitelist)
FRONTEND_URL=https://fna.sa

# PostgreSQL (for production — replace in-memory store)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telad_fleet
DB_USER=telad_user
DB_PASS=CHANGE_THIS_TO_STRONG_PASSWORD_20_CHARS

# Encryption & signing
ENCRYPTION_KEY=CHANGE_THIS_TO_32_CHAR_HEX_KEY
SIGNING_KEY=CHANGE_THIS_TO_32_CHAR_HEX_KEY

# Optional: ChatGPT / OpenAI integration
OPENAI_API_KEY=sk-CHANGE_THIS_TO_REAL_OPENAI_KEY

# Redis cache (optional)
REDIS_URL=redis://localhost:6379

# App URL
APP_URL=http://localhost:5000
