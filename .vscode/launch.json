{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Telad Fleet (Node)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server.js",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Telad Fleet Legacy (Python)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/server.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
